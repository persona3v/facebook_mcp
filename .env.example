FB_MARKETPLACE_DATA_DIR=~/.hermes/facebook-marketplace
FB_MARKETPLACE_HOME_LOCATION=Minneapolis, MN
FB_MARKETPLACE_SELLING_URL=https://www.facebook.com/marketplace/you/selling
FB_MARKETPLACE_MESSAGES_URL=https://www.facebook.com/marketplace/inbox

# Recommended for Phase 1: use a dedicated automation profile and log in manually.
# If unset, the server uses ~/.hermes/facebook-marketplace/browser-profile.
# FB_CHROME_USER_DATA_DIR=~/.hermes/facebook-marketplace/browser-profile

# Optional when using an installed Chrome channel instead of bundled Chromium.
# FB_BROWSER_CHANNEL=chrome

# Optional for an existing Chrome user data directory.
# FB_CHROME_PROFILE_NAME=Profile 1

FB_HEADLESS=false
FB_SLOW_MO_MS=50

# Apply puppeteer-extra-plugin-stealth fingerprint patches (navigator.webdriver, etc).
# Default: true. Set to false to debug without stealth shimming.
FB_STEALTH=true
